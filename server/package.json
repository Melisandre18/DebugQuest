{
  "name": "debugquest-server",
  "version": "1.0.0",
  "description": "DebugQuest backend — puzzles, analytics, adaptive engine",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import=tsx/esm --watch src/app.ts",
    "start": "node --env-file=.env --import=tsx/esm src/app.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
